{
  "info": {
    "name": "Admin Categories – Final Fixed",
    "description": "Полный набор тестов Admin: Категории. Запускать последовательно.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Подготовка: создать первую категорию (для удаления)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.collectionVariables.set('createdCategoryId', body.id);",
              "pm.collectionVariables.set('categoryName', body.name);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Initial Category\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories"]
        }
      }
    },
    {
      "name": "0b. Подготовка: создать вторую категорию (для конфликта имени)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.collectionVariables.set('secondCategoryId', body.id);",
              "pm.collectionVariables.set('secondCategoryName', body.name);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Second Category\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories"]
        }
      }
    },
    {
      "name": "1. POST /admin/categories - создание категории (успех)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Ответ содержит корректный CategoryDto', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('id');",
              "    pm.expect(body).to.have.property('name', 'Temporary Category');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Temporary Category\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories"]
        }
      }
    },
    {
      "name": "2. POST /admin/categories - ошибка 400 (пустое имя)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Ответ содержит поле reason', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body).to.have.property('reason');",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories"]
        }
      }
    },
    {
      "name": "3. POST /admin/categories - дубликат имени (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 409 Conflict', function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "pm.test('Ответ содержит поле reason', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body).to.have.property('reason');",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{categoryName}}\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories"]
        }
      }
    },
    {
      "name": "4. PATCH /admin/categories/{catId} - успешное обновление",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Имя изменилось на Updated Name', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.name).to.equal('Updated Name');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories/{{secondCategoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories", "{{secondCategoryId}}"]
        }
      }
    },
    {
      "name": "5. PATCH /admin/categories/{catId} - конфликт имени (409)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 409 Conflict', function () {",
              "    pm.response.to.have.status(409);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"{{categoryName}}\"\n}" },
        "url": {
          "raw": "{{baseUrl}}/admin/categories/{{secondCategoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories", "{{secondCategoryId}}"]
        }
      }
    },
    {
      "name": "6. DELETE /admin/categories/{catId} - успешное удаление",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/admin/categories/{{createdCategoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories", "{{createdCategoryId}}"]
        }
      }
    },
    {
      "name": "7. DELETE /admin/categories/{catId} - повторное удаление (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('Ответ содержит поле reason', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body).to.have.property('reason');",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/admin/categories/{{createdCategoryId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "categories", "{{createdCategoryId}}"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "categoryName", "value": "" },
    { "key": "createdCategoryId", "value": "" },
    { "key": "secondCategoryId", "value": "" },
    { "key": "secondCategoryName", "value": "" },
    { "key": "updatedName", "value": "Updated Name" }
  ]
}