{
  "info": {
    "name": "Admin Users Tests",
    "description": "Тесты для эндпоинтов администрирования пользователей (ExploreWithMe)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. POST /admin/users - создание пользователя (успех)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Ответ содержит корректный UserDto', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('id');",
              "    pm.expect(body).to.have.property('name', pm.variables.get('userName'));",
              "    pm.expect(body).to.have.property('email', pm.variables.get('userEmail'));",
              "});",
              "// Сохраняем id созданного пользователя для следующих тестов",
              "const userId = pm.response.json().id;",
              "pm.collectionVariables.set('createdUserId', userId);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        }
      }
    },
    {
      "name": "2. POST /admin/users - ошибка 400 (пустое имя)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "pm.test('Ответ содержит ApiError', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body).to.have.property('reason');",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"email\": \"invalid@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        }
      }
    },
    {
      "name": "3. GET /admin/users - получение всех пользователей",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Ответ - массив пользователей', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "});",
              "pm.test('Массив содержит созданного пользователя', function () {",
              "    const body = pm.response.json();",
              "    const userIds = body.map(user => user.id);",
              "    pm.expect(userIds).to.include(pm.collectionVariables.get('createdUserId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/admin/users?from=0&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "from",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "4. GET /admin/users - фильтр по ids",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Возвращен только запрошенный пользователь', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.lengthOf(1);",
              "    pm.expect(body[0].id).to.eql(pm.collectionVariables.get('createdUserId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/admin/users?ids={{createdUserId}}&from=0&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ],
          "query": [
            {
              "key": "ids",
              "value": "{{createdUserId}}"
            },
            {
              "key": "from",
              "value": "0"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "5. DELETE /admin/users/{userId} - удаление существующего пользователя",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/admin/users/{{createdUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users",
            "{{createdUserId}}"
          ]
        }
      }
    },
    {
      "name": "6. DELETE /admin/users/{userId} - повторное удаление (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус код 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('Ответ содержит ApiError', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('status');",
              "    pm.expect(body).to.have.property('reason');",
              "    pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/admin/users/{{createdUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users",
            "{{createdUserId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userName",
      "value": "Test User"
    },
    {
      "key": "userEmail",
      "value": "testuser@example.com"
    },
    {
      "key": "createdUserId",
      "value": ""
    }
  ]
}